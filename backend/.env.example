# FateDice Backend — 환경변수 템플릿
# 이 파일을 복사해서 .env 를 만들고 실제 값을 채워주세요.
# .env 파일은 절대 git에 커밋하지 마세요!

# 서버 설정
PORT=4000
NODE_ENV=development

# 프론트엔드 URL (CORS 허용)
FRONTEND_URL=http://localhost:3000

# Supabase 설정
# https://supabase.com 에서 프로젝트 생성 후 복사
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # 퍼블릭 anon key
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # ★ 서비스 롤 키 (백엔드 전용, 절대 프론트엔드 노출 금지)

# 내부 API 시크릿 (서버 간 통신 인증 — 결제 서버, 게임 서버 등)
# openssl rand -hex 32  로 생성 권장
INTERNAL_API_SECRET=replace-with-a-strong-random-secret-32chars
